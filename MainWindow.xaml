<Window x:Class="NetworkAnalyzerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Анализатор сетевых подключений"
        Height="760"
        Width="1200"
        MinHeight="700"
        MinWidth="1100">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.ColumnSpan="2"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"
                   Text="Практическая №2: анализ сетевых интерфейсов и URL/URI" />

        <GroupBox Grid.Row="1"
                  Grid.Column="0"
                  Header="Сетевые интерфейсы"
                  Margin="0,0,10,0">
            <DockPanel>
                <Button Content="Обновить список"
                        Margin="8"
                        Padding="10,6"
                        HorizontalAlignment="Left"
                        Click="RefreshInterfacesButton_Click"
                        DockPanel.Dock="Top" />
                <ListBox x:Name="InterfacesListBox"
                         Margin="8"
                         ItemsSource="{Binding NetworkInterfaces}"
                         SelectedIndex="0"
                         DisplayMemberPath="DisplayName" />
            </DockPanel>
        </GroupBox>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="Информация о выбранном интерфейсе" Margin="0,0,0,10">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Имя:" FontWeight="SemiBold" Margin="0,0,8,6" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedItem.Name, ElementName=InterfacesListBox}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Описание:" FontWeight="SemiBold" Margin="0,0,8,6" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedItem.Description, ElementName=InterfacesListBox}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="IP-адрес:" FontWeight="SemiBold" Margin="0,0,8,6" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedItem.IpAddress, ElementName=InterfacesListBox}" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Маска подсети:" FontWeight="SemiBold" Margin="0,0,8,6" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedItem.SubnetMask, ElementName=InterfacesListBox}" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="MAC-адрес:" FontWeight="SemiBold" Margin="0,0,8,6" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedItem.MacAddress, ElementName=InterfacesListBox}" />

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Состояние:" FontWeight="SemiBold" Margin="0,0,8,6" />
                    <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedItem.Status, ElementName=InterfacesListBox}" />

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Скорость:" FontWeight="SemiBold" Margin="0,0,8,6" />
                    <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedItem.Speed, ElementName=InterfacesListBox}" />

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Тип:" FontWeight="SemiBold" Margin="0,0,8,0" />
                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedItem.InterfaceType, ElementName=InterfacesListBox}" />
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="1" Header="Проверка URL/URI" Margin="0,0,0,10">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="UrlInputTextBox"
                             Grid.Row="0"
                             Grid.Column="0"
                             Margin="0,0,10,8"
                             Height="32"
                             VerticalContentAlignment="Center"
                             Text="https://example.com:443/path?q=1#part" />

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                Orientation="Horizontal">
                        <Button Content="Анализировать"
                                Padding="10,6"
                                Margin="0,0,8,8"
                                Click="AnalyzeUrlButton_Click" />
                        <Button Content="Очистить историю"
                                Padding="10,6"
                                Margin="0,0,0,8"
                                Click="ClearHistoryButton_Click" />
                    </StackPanel>

                    <TextBlock Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Foreground="#555"
                               Text="Поддерживаются URI с явной схемой (например, http:// или https://)." />
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="2" Header="Результаты анализа URL/URI" Margin="0,0,0,10">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10">
                    <TextBlock x:Name="UrlAnalysisResultTextBlock"
                               FontFamily="Consolas"
                               FontSize="13"
                               TextWrapping="Wrap" />
                </ScrollViewer>
            </GroupBox>

            <GroupBox Grid.Row="3" Header="История проверенных URL">
                <ListBox Margin="10"
                         ItemsSource="{Binding UrlHistory}" />
            </GroupBox>
        </Grid>
    </Grid>
</Window>
